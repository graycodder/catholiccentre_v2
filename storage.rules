rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public folders for blog and faculty images
    match /blogs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /faculty/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default rules: require authentication for other file access
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
