rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if a request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Leads/Applications: anyone can submit (create), only authenticated admins can read/update/delete
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // Courses: public can read, only authenticated admins can write
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Faculty: public can read, only authenticated admins can write
    match /faculty/{facultyId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Blogs: public can read, only authenticated admins can write
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
